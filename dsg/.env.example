# DatasetGateway environment variables
# Run `pixi run serve` — it will prompt for missing values and create .env.
# Or copy this file manually: cp .env.example .env

# Public origin (required — used for CSRF trusted origins)
DSG_ORIGIN=https://dataset-gateway.mydomain.org

# Server port
DSG_PORT=8200

# Google OAuth 2.0 credentials — place client_credentials.json in secrets/
# (env vars below override the file if set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Optional overrides below ---

# DJANGO_SECRET_KEY=change-me-to-a-random-string
# DJANGO_ALLOWED_HOSTS=dataset-gateway.mydomain.org
# DJANGO_DEBUG=False

# Cookie domain for cross-subdomain auth (e.g., .example.org)
# AUTH_COOKIE_DOMAIN=

# Regex for allowed CORS origins (Neuroglancer ngauth protocol)
# NGAUTH_ALLOWED_ORIGINS=^https?://.*\.neuroglancer\.org$

# Set to False if a reverse proxy handles TLS termination
# SECURE_SSL_REDIRECT=False

# Gunicorn settings
# GUNICORN_WORKERS=2
# LOG_LEVEL=info
