# DatasetGateway production environment variables
# Copy to .env and fill in values: cp .env.example .env

# REQUIRED — Django will refuse to start without these when DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_ALLOWED_HOSTS=dsg.example.org

# Set to False for production
DJANGO_DEBUG=False

# Google OAuth 2.0 credentials (required for login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cookie domain for cross-subdomain auth (e.g., .example.org)
# Leave empty if all services are on the same hostname.
AUTH_COOKIE_DOMAIN=

# Regex for allowed CORS origins (Neuroglancer ngauth protocol)
# NGAUTH_ALLOWED_ORIGINS=^https?://.*\.neuroglancer\.org$

# Set to False if a reverse proxy handles TLS termination
# SECURE_SSL_REDIRECT=False

# Gunicorn settings
# PORT=8080
# GUNICORN_WORKERS=2
# LOG_LEVEL=info
