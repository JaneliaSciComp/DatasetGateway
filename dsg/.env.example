# DatasetGateway environment variables — reference only.
# Run `pixi run setup` to generate .env interactively.

# --- Required ---
DSG_ORIGIN=https://dataset-gateway.mydomain.org
DSG_PORT=8200
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_ALLOWED_HOSTS=dataset-gateway.mydomain.org
DJANGO_DEBUG=True
SECURE_SSL_REDIRECT=False

# --- Optional ---
# AUTH_COOKIE_DOMAIN=.mydomain.org

# Google OAuth 2.0 — place client_credentials.json in secrets/
# (env vars below override the file if set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# NGAUTH_ALLOWED_ORIGINS=^https?://.*\.neuroglancer\.org$
# GUNICORN_WORKERS=2
# LOG_LEVEL=info
