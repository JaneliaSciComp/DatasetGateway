# DatasetGateway environment variables — reference only.
# Run `pixi run setup` to generate .env interactively.

# --- Required ---
DSG_ORIGIN=https://dataset-gateway.mydomain.org
DSG_PORT=8200
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_ALLOWED_HOSTS=dataset-gateway.mydomain.org
DJANGO_DEBUG=True
SECURE_SSL_REDIRECT=False

# --- Optional ---
# AUTH_COOKIE_DOMAIN=.mydomain.org

# Google OAuth 2.0 — place client_credentials.json in secrets/
# (env vars below override the file if set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# NGAUTH_ALLOWED_ORIGINS=^https?://.*\.neuroglancer\.org$
# GUNICORN_WORKERS=2
# LOG_LEVEL=info

# --- Backups (manage.py backup_db / restore_db; see docs/backups.md) ---
# DSG_BACKUP_STAGING_DIR=/var/tmp/dsg-backups          # fast local NVMe scratch
# DSG_BACKUP_DIR=/shared/flyem/dsg                     # slow nearline target
# DSG_BACKUP_KEEP_HOURLY=24
# DSG_BACKUP_KEEP_DAILY=14
# DSG_BACKUP_KEEP_WEEKLY=8
# DSG_BACKUP_INCLUDE_SECRETS=true                      # bundle .env + secrets/ too
# DSG_BACKUP_AGE_RECIPIENTS_FILE=/etc/dsg/age-recipients.txt  # admin public keys (age -R)
# DSG_BACKUP_AGE_IDENTITY_FILE=/etc/dsg/age-identity.txt      # restore-side private key
# Pluggable encrypt/decrypt overrides (stdin->stdout); take precedence over age:
# DSG_BACKUP_ENCRYPT_CMD=
# DSG_BACKUP_DECRYPT_CMD=
